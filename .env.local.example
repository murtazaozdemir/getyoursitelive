# -----------------------------------------------------------------------------
# Local development environment. Copy to .env.local (do not commit .env.local).
# -----------------------------------------------------------------------------

# Both local dev AND production point to the same R2 bucket — one database, one truth.
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
STORAGE_BACKEND=r2
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=getyoursitelive

# Secret used to sign admin session cookies. MUST be at least 32 characters.
# Generate a fresh one with:  openssl rand -base64 48
AUTH_SECRET=change-me-to-a-random-48-plus-character-string-before-running

# Public URL (used for preview links etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
