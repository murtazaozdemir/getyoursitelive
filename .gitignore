# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sqlite database (local/dev; committed seed scripts recreate it)
/db/db.sqlite
/db/db.sqlite-journal
/db/db.sqlite-wal
/db/db.sqlite-shm

# user-uploaded files (logo, photos, etc.) — not tracked in git
/public/uploads/

# on-demand screenshot cache — regenerated by /api/screenshot at runtime
/public/proposal-screenshots/

# sensitive data — not for public repo
data/users.json
# prospects.json is committed so it deploys to Vercel for the seed-blob endpoint

# internal sales docs — not for public repo
HANDOUT-PROPOSAL-*.md
HANDOUT-PROPOSAL-*.docx
INTERNAL-*.md
AutoRepairSiteTemp/
client-site/

# unrelated tools in project root — not part of this repo
ScreenShotTool-master/
rest-screenshoot-master/
